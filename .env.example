# Production form delivery through Resend's HTTPS email API.
RESEND_API_KEY=
AFRIBRIDGE_FORM_FROM="AfriBridge AgroTrade <forms@afribridgeagro.trade>"
AFRIBRIDGE_FORM_RECIPIENTS="udo@afribridgeagro.trade,sulley@afribridgeagro.trade"

# Comma-separated production and preview origins allowed to POST forms.
AFRIBRIDGE_ALLOWED_ORIGINS="https://afribridgeagro.trade,https://www.afribridgeagro.trade"

# Best-effort in-memory form rate limiting.
AFRIBRIDGE_RATE_LIMIT_WINDOW_MS=600000
AFRIBRIDGE_RATE_LIMIT_MAX=5

# Optional fallback delivery to a secure HTTPS automation endpoint.
AFRIBRIDGE_FORM_WEBHOOK_URL=
AFRIBRIDGE_FORM_WEBHOOK_TOKEN=
